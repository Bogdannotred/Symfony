{% extends 'base.html.twig' %}

{% block title %}Task index{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-6 py-12">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
        <div>
            <h1 class="text-5xl font-extrabold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-purple-600 mb-2">
                My Universe
            </h1>
            <p class="text-slate-500 font-medium">Manage your goals with elegance.</p>
        </div>
        <a href="{{ path('app_task_new') }}" class="modern-btn group flex items-center gap-2 text-white px-8 py-4 rounded-2xl shadow-lg transition-all font-bold">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:rotate-90 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Create Task
        </a>
    </div>

    <!-- Filters Section -->
    <div class="glass-card p-6 mb-12">
        <form action="{{ path('app_task_index') }}" method="GET" class="grid grid-cols-1 md:grid-cols-4 gap-6 items-end">
            <div class="md:col-span-2">
                <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2 ml-1">Search</label>
                <input type="text" name="search" placeholder="Find a task..." value="{{ app.request.query.get('search') }}"
                       class="glass-input w-full px-5 py-3 rounded-xl focus:outline-none placeholder:text-slate-300">
            </div>

            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2 ml-1">Direction</label>
                <select name="direction" onchange="this.form.submit()" class="glass-input w-full px-5 py-3 rounded-xl focus:outline-none appearance-none bg-white/50">
                    <option value="ASC" {{ app.request.query.get('direction') == 'ASC' ? 'selected' : '' }}>Oldest First</option>
                    <option value="DESC" {{ app.request.query.get('direction') == 'DESC' ? 'selected' : '' }}>Newest First</option>
                </select>
            </div>

            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2 ml-1">Status</label>
                <select name="status" onchange="this.form.submit()" class="glass-input w-full px-5 py-3 rounded-xl focus:outline-none appearance-none bg-white/50">
                    <option value="All" {{ app.request.query.get('status') == 'All' ? 'selected' : '' }}>All Tasks</option>
                    <option value="Open" {{ app.request.query.get('status') == 'Open' ? 'selected' : '' }}>Open</option>
                    <option value="Done" {{ app.request.query.get('status') == 'Done' ? 'selected' : '' }}>Done</option>
                </select>
            </div>
        </form>
    </div>

    <!-- Tasks Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {% for task in tasks %}
        <div class="glass-card glass-card-hover p-8 relative flex flex-col h-full group">
            <div class="flex justify-between items-start mb-6">
                {% if task.isDone %}
                    <span class="px-4 py-1.5 text-[10px] font-black uppercase tracking-widest text-emerald-600 bg-emerald-100/50 rounded-full border border-emerald-200">Completed</span>
                {% else %}
                    <span class="px-4 py-1.5 text-[10px] font-black uppercase tracking-widest text-amber-600 bg-amber-100/50 rounded-full border border-amber-200">In Progress</span>
                {% endif %}
                <span class="text-xs font-bold text-slate-400">{{ task.createdAt ? task.createdAt|date('d M Y') : '' }}</span>
            </div>
            
            <h3 class="text-2xl font-bold text-slate-800 mb-3 group-hover:text-indigo-600 transition-colors">{{ task.title }}</h3>
            <p class="text-slate-500 leading-relaxed mb-8 flex-grow">
                {{ task.description|default('No description provided.')|length > 120 ? task.description|slice(0, 120) ~ '...' : task.description }}
            </p>

            <div class="flex items-center justify-between pt-6 border-t border-slate-100">
                <div class="flex gap-2">
                    <a href="{{ path('app_task_edit', {'id': task.id}) }}" class="p-2.5 text-amber-500 hover:bg-amber-50 rounded-xl transition-colors" title="Edit Task">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                    </a>
                    <a href="{{ path('app_task_show', {'id': task.id}) }}" class="p-2.5 text-indigo-500 hover:bg-indigo-50 rounded-xl transition-colors" title="View Details">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                    </a>
                </div>
                
                <a href="{{ path('app_task_show', {'id': task.id}) }}" class="text-indigo-600 font-bold text-sm flex items-center gap-1 group/btn min-w-max">
                    View Details
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </a>
            </div>
        </div>
    {% else %}
        <div class="col-span-full glass-card p-20 text-center">
            <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 9.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <h3 class="text-2xl font-bold text-slate-800 mb-2">No tasks found</h3>
            <p class="text-slate-500 max-w-sm mx-auto">Your universe is empty. Create your first task to begin your journey!</p>
        </div>
    {% endfor %}
    </div>

    <!-- Footer / User Info -->
    <div class="mt-24 glass-card p-10 flex flex-col md:flex-row justify-between items-center gap-8 bg-gradient-to-br from-indigo-50/50 via-white/50 to-purple-50/50">
        <div class="flex items-center gap-4">
            <div class="w-16 h-16 bg-white rounded-2xl shadow-sm flex items-center justify-center text-2xl">
                👤
            </div>
            <div>
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Authenticated As</p>
                <p class="text-xl font-bold text-slate-800">{{ app.user.email }}</p>
            </div>
        </div>
        <a href="{{ path('app_logout') }}" class="px-8 py-3.5 rounded-xl border-2 border-slate-200 text-slate-600 font-bold hover:bg-rose-50 hover:border-rose-200 hover:text-rose-600 transition-all">
            Sign Out
        </a>
    </div>
</div>
{% endblock %}