{# templates/task/_form.html.twig #}

<div class="glass-card p-10 max-w-2xl mx-auto">
    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'space-y-8'}}) }}

        {# Câmpul pentru Titlu #}
        <div>
            {{ form_label(form.title, 'Task Title', {'label_attr': {'class': 'block text-xs font-bold text-slate-400 uppercase tracking-widest mb-3 ml-1'}}) }}
            
            {{ form_widget(form.title, {
                'attr': {
                    'class': 'glass-input block w-full px-6 py-4 rounded-2xl focus:outline-none text-slate-700 font-medium placeholder:text-slate-300',
                    'placeholder': 'What needs to be done?'
                }
            }) }} 
            
            {% if form_errors(form.title) %}
                <div class="mt-3 text-sm text-rose-500 flex items-center gap-2 font-medium">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                    {{ form_errors(form.title) }}
                </div>
            {% endif %}
        </div>

        {# Câmpul pentru Descriere #}
        <div>
            {{ form_label(form.description, 'Description (Optional)', {'label_attr': {'class': 'block text-xs font-bold text-slate-400 uppercase tracking-widest mb-3 ml-1'}}) }}
            
            {{ form_widget(form.description, {
                'attr': {
                    'class': 'glass-input block w-full px-6 py-4 rounded-2xl focus:outline-none text-slate-700 font-medium placeholder:text-slate-300',
                    'placeholder': 'Add more details about this task...',
                    'rows': '5'
                }
            }) }}
            
            {% if form_errors(form.description) %}
                <div class="mt-3 text-sm text-rose-500 font-medium">
                    {{ form_errors(form.description) }}
                </div>
            {% endif %}
        </div>

        {# Câmpul pentru Status #}
        {% if form.isDone is defined %}
        <label class="flex items-center gap-4 cursor-pointer group">
            <div class="relative">
                {{ form_widget(form.isDone, {'attr': {'class': 'sr-only peer'}}) }}
                <div class="w-12 h-6 bg-slate-200 rounded-full peer peer-checked:bg-indigo-600 transition-colors after:content-[''] after:absolute after:top-1 after:left-1 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-6"></div>
            </div>
            <span class="text-sm font-bold text-slate-600 group-hover:text-indigo-600 transition-colors">Mark as completed</span>
        </label>
        {% endif %}

        {# Butonul de Acțiune #}
        <div class="pt-6">
            <button type="submit" class="modern-btn w-full flex justify-center py-5 px-6 rounded-2xl shadow-xl text-white font-black uppercase tracking-widest text-sm transition-all">
                {{ button_label|default('Save Objective') }}
            </button>
        </div>

    {{ form_end(form) }}
</div>