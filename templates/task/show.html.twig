{% extends 'base.html.twig' %}

{% block title %}Task Details: {{ task.title }}{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-6 py-16">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-8 mb-12">
        <div>
            <a href="{{ path('app_task_index') }}" class="group inline-flex items-center gap-3 text-sm font-bold text-slate-400 hover:text-indigo-600 transition-colors mb-4">
                <div class="p-2 bg-white rounded-xl shadow-sm group-hover:bg-indigo-50 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                </div>
                Return to Dashboard
            </a>
            <h1 class="text-5xl font-extrabold tracking-tight text-slate-800">Objective Insights</h1>
        </div>

        <div class="flex items-center gap-4">
            <a href="{{ path('app_task_edit', {'id': task.id}) }}" class="modern-btn group flex items-center gap-2 text-white px-8 py-4 rounded-2xl shadow-lg transition-all font-bold">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                </svg>
                Refine Objective
            </a>
        </div>
    </div>

    <!-- Content Card -->
    <div class="glass-card overflow-hidden">
        <div class="grid grid-cols-1 md:grid-cols-4">
            
            <!-- Sidebar Stats -->
            <div class="p-10 border-b md:border-b-0 md:border-r border-slate-100 bg-slate-50/30 flex flex-col justify-center items-center text-center">
                <div class="mb-10">
                    <div class="text-xs font-black text-slate-400 uppercase tracking-widest mb-3">Priority Hash</div>
                    <div class="text-3xl font-black text-indigo-600">#{{ task.id }}</div>
                </div>
                
                <div>
                    <div class="text-xs font-black text-slate-400 uppercase tracking-widest mb-4">Lifecycle State</div>
                    {% if task.isDone %}
                        <div class="inline-flex flex-col items-center gap-2">
                            <div class="w-16 h-16 bg-emerald-100 rounded-2xl flex items-center justify-center text-emerald-600 text-2xl mb-2">
                                ✅
                            </div>
                            <span class="text-xs font-black uppercase tracking-widest text-emerald-600">Completed</span>
                        </div>
                    {% else %}
                        <div class="inline-flex flex-col items-center gap-2">
                            <div class="w-16 h-16 bg-amber-100 rounded-2xl flex items-center justify-center text-amber-600 text-2xl mb-2">
                                ⏳
                            </div>
                            <span class="text-xs font-black uppercase tracking-widest text-amber-600">In Progress</span>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Main Info -->
            <div class="md:col-span-3 p-10 lg:p-16">
                <div class="mb-12">
                    <h2 class="text-xs font-black text-indigo-400 uppercase tracking-[0.2em] mb-4">Objective Title</h2>
                    <p class="text-4xl text-slate-800 font-black leading-tight tracking-tight">{{ task.title }}</p>
                </div>

                <div>
                    <h2 class="text-xs font-black text-indigo-400 uppercase tracking-[0.2em] mb-4">Detailed Specifications</h2>
                    <div class="text-xl text-slate-500 font-medium leading-relaxed">
                        {{ task.description ?: 'Unspecified details for this objective.' }}
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Footer -->
        <div class="px-10 py-6 bg-slate-50/50 border-t border-slate-100 flex justify-between items-center">
            <span class="text-xs font-bold text-slate-300 uppercase tracking-widest">
                Registered on {{ task.createdAt ? task.createdAt|date('d F Y') : 'Unknown Date' }}
            </span>
            <div class="transform scale-90 opacity-40 hover:opacity-100 transition-all">
                {{ include('task/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>

<style>
    /* Styling for the delete button in show view to match the theme */
    .delete-form-wrapper button, 
    form[action*="delete"] button {
        background: transparent;
        color: #94a3b8;
        padding: 0.5rem 1rem;
        border-radius: 12px;
        font-weight: 800;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: all 0.3s ease;
    }
    form[action*="delete"] button:hover {
        color: #e11d48;
        background: #fff1f2;
    }
</style>
{% endblock %}