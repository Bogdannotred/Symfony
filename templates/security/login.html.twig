{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col justify-center py-12 px-6 lg:px-8 relative">
    <!-- Decorative background elements -->
    <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-indigo-400/20 blur-[100px] rounded-full"></div>
    <div class="absolute bottom-1/4 right-1/4 w-64 h-64 bg-purple-400/20 blur-[100px] rounded-full"></div>

    <div class="sm:mx-auto sm:w-full sm:max-w-md relative z-10">
        <div class="text-center mb-10">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-white rounded-3xl shadow-xl mb-6 text-3xl">
                ⚡️
            </div>
            <h2 class="text-4xl font-black text-slate-800 tracking-tight">Welcome Back</h2>
            <p class="mt-3 text-slate-500 font-medium">Continue your journey in the universe.</p>
        </div>

        <div class="glass-card p-10">
            <form method="post" class="space-y-8">
                {% if error %}
                    <div class="bg-rose-50 border border-rose-100 p-4 rounded-2xl flex items-center gap-3">
                        <svg class="h-5 w-5 text-rose-500" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                        </svg>
                        <p class="text-sm text-rose-700 font-bold">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </p>
                    </div>
                {% endif %}

                {% if app.user %}
                    <div class="bg-indigo-50 border border-indigo-100 p-4 rounded-2xl text-sm text-indigo-700 font-bold">
                        You are logged in as <span class="text-indigo-900 underline">{{ app.user.userIdentifier }}</span>.
                        <a href="{{ path('app_logout') }}" class="ml-2 text-rose-600 hover:text-rose-700">Logout?</a>
                    </div>
                {% endif %}

                <div>
                    <label for="inputEmail" class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-3 ml-1">Email Identifier</label>
                    <input type="email" value="{{ last_username }}" name="email" id="inputEmail" required autofocus
                           class="glass-input block w-full px-6 py-4 rounded-2xl focus:outline-none text-slate-700 font-medium placeholder:text-slate-300"
                           placeholder="name@universe.com">
                </div>

                <div>
                    <label for="inputPassword" class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-3 ml-1">Security Key</label>
                    <input type="password" name="password" id="inputPassword" required autocomplete="current-password"
                           class="glass-input block w-full px-6 py-4 rounded-2xl focus:outline-none text-slate-700 font-medium placeholder:text-slate-300"
                           placeholder="••••••••">
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="flex items-center justify-between px-1">
                    <label class="flex items-center gap-3 cursor-pointer group">
                        <div class="relative">
                            <input id="remember_me" name="_remember_me" type="checkbox" class="sr-only peer">
                            <div class="w-10 h-5 bg-slate-200 rounded-full peer peer-checked:bg-indigo-600 transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5"></div>
                        </div>
                        <span class="text-xs font-bold text-slate-500 group-hover:text-indigo-600 transition-colors">Keep me active</span>
                    </label>

                    <a href="#" class="text-xs font-bold text-indigo-600 hover:text-indigo-800 transition-colors">Recover Keys?</a>
                </div>

                <button type="submit" class="modern-btn w-full flex justify-center py-5 px-6 rounded-2xl shadow-xl text-white font-black uppercase tracking-widest text-sm transition-all">
                    Initialize Access
                </button>
            </form>
        </div>

        <p class="mt-10 text-center text-xs font-bold text-slate-400 uppercase tracking-[0.2em]">
            New to the Universe? <a href="#" class="text-indigo-600 hover:text-indigo-500 underline underline-offset-4">Create Account</a>
        </p>
    </div>
</div>
{% endblock %}